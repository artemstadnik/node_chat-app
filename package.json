{
  "name": "node_chat-app",
  "version": "1.0.0",
  "description": "Real-time multi-room chat application with React, Node.js, and Socket.IO",
  "scripts": {
    "start:server": "npm start --prefix server",
    "start:client": "npm run dev --prefix client",
    "lint": "npm run format && eslint './server/src/**/*.{js,ts}' './client/src/**/*.{js,jsx,ts,tsx}'",
    "format": "prettier --ignore-path .prettierignore --write './server/src/**/*.{js,ts}' './client/src/**/*.{js,jsx,ts,tsx}'"
  },
  "author": "Artem Stadnik",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.3.2"
  }
}
